{
  "name": "@ecommerce/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../apps/api/.env -- prisma migrate deploy",
    "studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "db:push": "dotenv -e ../../apps/api/.env -- prisma db push",
    "seed": "dotenv -e ../../apps/api/.env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../apps/api/.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@ecommerce/config": "workspace:*",
    "@faker-js/faker": "^9.8.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  }
}
