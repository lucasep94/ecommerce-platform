{
  "name": "@ecommerce/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../apps/api/.env -- prisma migrate deploy",
    "studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "db:push": "dotenv -e ../../apps/api/.env -- prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@ecommerce/config": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.8.0",
    "typescript": "^5.6.3"
  }
}
